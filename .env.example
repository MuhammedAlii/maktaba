# Firebase Configuration
# Bu dosyayı .env olarak kopyalayın ve kendi Firebase bilgilerinizi girin
# cp .env.example .env
#
# Vercel: aynı VITE_* değişkenlerini Project → Settings → Environment Variables
# içine ekleyin; deploy sonrası Firebase Auth → Authorized domains’e *.vercel.app ekleyin.
# Ayrıntı: VERCEL_DEPLOY.md

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# Cloudinary — profil fotoğrafı yükleme (unsigned upload preset gerekir)
# Dashboard: https://console.cloudinary.com/ → Settings → Upload → Upload presets
# Preset: Signing mode = Unsigned (overwrite kapalı olabilir; uygulama her yüklemede yeni public_id kullanır).
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name

# EmailJS - Şifremi unuttum için email gönderimi (opsiyonel)
# Yapılandırılmazsa kod ekranda gösterilir
# https://www.emailjs.com/ adresinden ücretsiz hesap oluşturun
# Template'de {{code}}, {{email}} veya {{to_email}}, logo için {{logo_url}} kullanın
# VITE_EMAILJS_SERVICE_ID=service_xxxxx
# VITE_EMAILJS_TEMPLATE_ID=template_xxxxx
# VITE_EMAILJS_PUBLIC_KEY=your_public_key
# Logo için (opsiyonel): VITE_APP_LOGO_URL=https://siteniz.com/maktaba-logo.png
